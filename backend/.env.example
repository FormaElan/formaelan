# FormaElan backend environment
# Copier en backend/.env pour le local. Sur Render, renseigner ces valeurs dans Environment.
# Ne jamais committer backend/.env.

# Site public
SITE_URL=https://formaelan.fr
PORT=4242

# Stripe live
STRIPE_SECRET_KEY=sk_live_REMPLACER
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER

# Stripe Price IDs live
PRICE_SEO_SAAS=price_REMPLACER
PRICE_IA_FREELANCE=price_REMPLACER
PRICE_COPYWRITING_ECOM=price_REMPLACER
PRICE_SEO_ECOM=price_REMPLACER
PRICE_OPTIMISER_IA=price_REMPLACER
PRICE_SEO_CREATEURS=price_REMPLACER

# Email Resend
RESEND_API_KEY=re_REMPLACER

# Admin support: POST /admin/resend-access
ACCESS_ADMIN_SECRET=REMPLACER_PAR_UN_SECRET_LONG

# Recommandé avant live pour persister les tokens d'accès après redéploiement Render
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
